# =====================================
# [dns] - 继承 v5.1.3 (大幅收敛, 仅 AI 强制境外 DoH)
# =====================================
[dns]
no-ipv6
prefer-doh3

# 主 DoH: 国内双供应商
doh-server=https://dns.alidns.com/dns-query, https://doh.pub/dns-query

# AI 服务: 强制境外 DoH (防国内 DNS 间歇污染)
# v5.1.7 [安全] 补 Cloudflare 次要 IP 1.0.0.1 冗余 (对齐 SR v2.6.9):
#   单一 1.1.1.1 端点被阻断时, 可 fallback 到 1.0.0.1, 避免回退系统 DNS
#   拿污染 IP. 与 SR 同款做法.
doh-server=/*.openai.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.chatgpt.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.oaistatic.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.oaiusercontent.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.anthropic.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.claude.ai/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/gemini.google.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/*.generativelanguage.googleapis.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
doh-server=/aistudio.google.com/https://1.1.1.1/dns-query,https://1.0.0.1/dns-query

# v5.1.5 新增: 社交阅读站 + 其 CDN 走境外 DoH (防污染/防错误调度)
# LinkedIn
