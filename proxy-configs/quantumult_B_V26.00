[rewrite_local]


# =====================================
# [rewrite_remote] - v5.1.4 能耗: 3天更新
# =====================================
# YouTube 去广告/小窗 (V26.00 功能审查注记): QX 不提供 ——
#   Maasea 方案的核心是 binary-body-mode=1 的 protobuf 响应改写脚本,
#   QX 改写语法无此参数、上游模块无 QX 适配版, 硬移植会静默损坏播放.
#   YouTube 去广告+画中画需求请用 SR / Egern / Loon (三套链路完整).
#   QX 保留: YouTube 分流 + udp_whitelist 强制 TCP (播放稳定性不受影响).
[rewrite_remote]
https://github.com/chavyleung/scripts/raw/master/box/rewrite/boxjs.rewrite.quanx.conf, tag=BoxJs, update-interval=259200, opt-parser=false, enabled=true
https://github.com/sub-store-org/Sub-Store/raw/master/config/QX.snippet, tag=Sub-Store, update-interval=259200, opt-parser=false, enabled=true
https://raw.githubusercontent.com/Script-Hub-Org/Script-Hub/main/modules/script-hub.beta.qx.conf, tag=Script-Hub, update-interval=259200, opt-parser=false, enabled=true
# Spotify VIP 解锁 (灰色功能, 用户自行评估)
https://raw.githubusercontent.com/app2smile/rules/master/module/spotify.conf, tag=Spotify音乐VIP, update-interval=259200, opt-parser=false, enabled=true


[task_local]
# 提示: 若非常用, 可在 App 内将非刚需项勾选 Disabled 进一步降耗
#
# ───────────────────────────────────────────────────────────────────
# 手动交互查询 (event-interaction): 点按触发, 弹 UI. 保持原样.
# ───────────────────────────────────────────────────────────────────
event-interaction https://raw.githubusercontent.com/KOP-XIAO/QuantumultX/master/Scripts/streaming-ui-check.js, tag=流媒体-解锁查询, img-url=checkmark.seal.system, enabled=true
event-interaction https://raw.githubusercontent.com/I-am-R-E/Functional-Store-Hub/Master/NodeLinkCheck/Script/NodeLinkCheck.js, tag=链路检测, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Stack.png, enabled=true
event-interaction https://raw.githubusercontent.com/fmz200/wool_scripts/main/QuantumultX/scripts/server_info.js, tag=节点详情查询, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/ipInfo.png, enabled=true
event-interaction https://raw.githubusercontent.com/KOP-XIAO/QuantumultX/master/Scripts/traffic-check.js, tag=策略流量查询, img-url=arrow.up.arrow.down.circle.system, enabled=true
event-interaction https://raw.githubusercontent.com/KOP-XIAO/QuantumultX/master/Scripts/server-info-plus.js, tag=节点信息查询, img-url=tag.circle.system, enabled=true

# ───────────────────────────────────────────────────────────────────
# V26.00 [能力] cron 定时任务 (落地 QX 独有强项, 对齐 CLAUDE.md §二)
# ───────────────────────────────────────────────────────────────────
# QX cron 语法: <分> <时> <日> <月> <周> <script-url>, tag=..., enabled=...
# ⚠️ 以下三条默认 enabled=false: 它们依赖你机场专属脚本 / 你的账号,
#    必须先把 script-path 换成可用的真实脚本(并在 App 内授权)再开启,
#    否则会拉到 404 / 空跑. 占位 URL 仅示意位置, 不可直接用.
#
# (1) 机场订阅到期 / 流量提醒 —— 每日 09:00
#     依赖: 你机场提供的"订阅信息/流量查询"脚本(各家 API 不同, 无通用源).
#     真实源举例: 机场面板给的 QX 任务脚本, 或 BoxJS 里对应机场的 checkin.
0 9 * * * https://YOUR_AIRPORT/path/to/subscription-info.js, tag=订阅流量提醒, img-url=arrow.up.arrow.down.circle.system, enabled=false

# (2) 节点链路健康巡检 —— 每日 09:00 与 21:00 各一次
#     复用已在用的 NodeLinkCheck.js(同上 event 版本); cron 版无人值守巡检.
#     注: 该脚本原为交互式, 启用前请确认它在 cron 下会"仅在异常时通知"
#     而非每次弹窗; 若每次都通知会打扰, 调成每日 1 次或改用静默健康脚本.
0 9,21 * * * https://raw.githubusercontent.com/I-am-R-E/Functional-Store-Hub/Master/NodeLinkCheck/Script/NodeLinkCheck.js, tag=链路巡检, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Stack.png, enabled=false

# (3) 签到类任务 (示例占位) —— 每日 08:05
#     依赖: 你要签到的服务对应脚本 + 已在 App/BoxJS 内捕获的 Cookie/账号.
#     灰色功能, 自行评估合规与风控. 换成真实脚本后再开启.
5 8 * * * https://YOUR_SERVICE/path/to/checkin.js, tag=每日签到, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/ipInfo.png, enabled=false


[http_backend]


# =====================================
# [mitm] - v5.1.4 安全加固: 关闭全局证书豁免
# =====================================
[mitm]
# V26.00 [一致性] 补 -security.weibo.cn / -account.zhihu.com, 对齐四套基线
hostname = -www.google.com, -passport.weibo.cn, -login.sina.com.cn, -security.weibo.cn, -pay.weibo.cn, -account.bilibili.com, -passport.bilibili.com, -pay.bilibili.com, -account.zhihu.com, -*.alipay.com, -*.unionpay.com, -*.cmbchina.com, -*.icbc.com.cn, -*.icloud.com
skip_validating_cert = false
;passphrase =
;p12 =
