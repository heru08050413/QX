#############################################
# 配置版本: V26.00 (四套配置统一版本号; B 派, 历史沿革见下方 v5.1.x 日志)
#
# v5.1.5 → v5.1.6 改动:
#   1. [修复] 删除报错的 Quora.list 远程订阅 (bm7 仓库无此目录, 404).
#      改用 filter_local 本地手写规则覆盖 quora.com / quoracdn.net,
#      走社交阅读组. 本地规则立即生效, 不依赖远程, 更可靠.
#   2. [明确化] Privacy / BlockHttpDNS 显式 force-policy=reject.
#      理由: 拦截类规则集的语义就是"拒绝", reject 让连接直接失败,
#      不影响 App 主功能, 但掐断追踪上报 / 私有 DNS 绕过.
#
# ===== 以下为 v5.1.5 原始说明 =====
# 配置版本: B 派 v5.1.5 - 社交阅读站加速 (A+B 方向)
#
# v5.1.4 → v5.1.5 改动 (LinkedIn/Quora/Tumblr/Reddit 慢的修复):
#   诊断: 这四站原走兜底策略, 慢的原因有三:
#     (1) DNS 走阿里/腾讯, 海外站解析慢或调度到错误 CDN
#     (2) LinkedIn 部分域名被 ChinaMax 判国内 → 路径分裂(部分直连
#         国际版导致极慢)
#     (3) 自动选择按延迟挑节点, 但低延迟≠对这些站高吞吐
#
#   方向A (DNS): [dns] 新增四站及其 CDN 的 Cloudflare DoH 防污染.
#     CDN 域名 (licdn/quoracdn/redditstatic 等) 必须一起加, 否则
#     主域名解析对了但图片/资源仍走老路, 页面照样卡.
#
#   方向B (策略+规则):
#     - [policy] 新增 static=社交阅读, 默认美国节点 (源站在美, 吞吐最好)
#       复用现有地区组, 不新建测速组 → 零能耗增加
#     - [filter_remote] 四站 bm7 原生规则, force-policy=社交阅读
#     - 关键: 放在 ChinaMax 之前, 根治 LinkedIn 路径分裂
#       (即便被判国内, 也先被社交阅读规则拦截走代理)
#
#   三维影响:
#     功能: 显著正面 (路径分裂根治 + DNS 加速 + 可手选优质节点)
#     安全: 持平偏正面 (DNS 走 Cloudflare 加密; 不涉 MITM/证书)
#     能耗: 接近零 (复用现有地区组不新建测速组; DNS 多匹配纳秒级;
#           filter 多 4 条订阅但 7 天更新, 日均增量可忽略)
#
# ===== 以下为 v5.1.4 原始说明 =====
# 配置版本: B 派 v5.1.4 - 三向专家会审能耗加固版
#
# v5.1.3 → v5.1.4 改动:
#   1. [修 BUG] filter_local 的 geoip CN 补上 no-resolve
#      病灶: 缺 no-resolve 时, 每个国内纯 IP 包都触发一次 DNS 反查,
#            既增加延迟又拉高基带唤醒能耗 (与降耗目标直接矛盾).
#      修复: geoip, CN, direct, no-resolve
#
#   2. [安全] skip_validating_cert: true → false
#      病灶: 全局放弃上游证书校验, 公共 WiFi 钓鱼/骨干网劫持时
#            可被无感知中间人攻击.
#      影响: 绝大多数 rewrite 在 false 下正常工作.
#
#   3. [能耗] 远程规则 update-interval 分级拉长:
#            广告/隐私/ChinaMax: 1天 → 3天 (259200)
#            AI/流媒体/社交:     1天 → 7天 (604800)
#      理由: bm7 规则集变化极慢, 每天 18 次后台握手 + 解析数万条
#            规则写闪存是不必要的 CPU/IO 唤醒.
#
#   4. [效率] filter_local 国内硬编码分级清理:
#            删除: 视频/出行/工具类 (偶尔绕路无伤大雅, 交给 ChinaMax)
#            保留: 财经/证券类 (cert-pinning 长连接, 最怕 ChinaMax
#                  加载失败时绕路, 作为离线降级保险)
#
# ⚠️ 会审报告中两条被否决的建议 (避免引入新问题):
#   - 否决"将整个 qq.com 设 direct": qq.com 是泛域名, gdt.qq.com
#     等腾讯广告/追踪域名会因此绕过广告拦截. 微信通话的直连靠
#     geoip CN + fallback_udp_policy=direct 已足够.
#   - 否决"删光全部国内硬编码": 财经类保留作离线保险 (见上).
#
# 继承自 v5.1.x 的核心防护 (100% 保留):
#   - 微信语音 UDP 双重保护 (geoip CN + fallback_udp_policy)
#   - AI 服务境外 DoH 防污染
#   - IG/Twitter 900s 稳定池防风控漂移
#   - 银行/支付 MITM 排除清单
#   - 策略组类型严格分层 (static 嵌套 / url-latency 纯节点)
#
# 更新时间: 2026-05-23
#############################################

[general]
server_check_url=http://cp.cloudflare.com/generate_204
server_check_timeout=3000

profile_img_url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/author/fmz200-01.png

# 银行/券商域名: 不走 QX DoH, 用系统 DNS, 避免 cert-pinning 风控
dns_exclusion_list=*.cmpassport.com, *.jegotrip.com.cn, *.icitymobile.mobi, id6.me, *.pingan.com.cn, *.cmbchina.com, *.ccb.com, *.icbc.com.cn, *.boc.cn, *.abchina.com.cn, *.myhexin.com, *.eastmoney.com

geo_location_checker=http://ip-api.com/json/?lang=zh-CN, https://raw.githubusercontent.com/fmz200/wool_scripts/main/QuantumultX/scripts/server_location.js

# V26.00 [连通性] fastly.jsdelivr → raw.githubusercontent (jsDelivr 国内常被墙, 已验证 raw 200)
resource_parser_url=https://raw.githubusercontent.com/KOP-XIAO/QuantumultX/master/Scripts/resource-parser.js

excluded_routes=192.168.0.0/16, 172.16.0.0/12, 100.64.0.0/10, 10.0.0.0/8, 239.255.255.250/32

fallback_udp_policy=direct

# V26.00 [统一 QUIC 策略, CLAUDE.md §一.6] 排除 UDP 428-443 端口段:
#   QX 无协议级规则 (不能像 SR/Egern 写 AND(域名+QUIC)REJECT), 阻断
#   QUIC 的架构内唯一手段是 udp_whitelist (官方样例注释即此写法, 不在
#   名单的 UDP 端口被丢弃并回 ICMP 端口不可达). 效果: UDP 443
#   (QUIC/HTTP3) 全局阻断→客户端回落 TCP, 保证 MITM/rewrite 去广告
#   链路不被 HTTP/3 绕过; DNS(53)、微信 VOIP/游戏/FaceTime (高位端口,
#   均在 444-65535) 不受影响.
udp_whitelist=53, 80-427, 444-65535


# =====================================
# [dns] - 继承 v5.1.3 (大幅收敛, 仅 AI 强制境外 DoH)
# =====================================
[dns]
no-ipv6
prefer-doh3

# 主 DoH: 国内双供应商
doh-server=https://dns.alidns.com/dns-query, https://doh.pub/dns-query

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# V26.00 [勘误] 删除 v5.1.3~v5.1.5 累积的 18 行 per-domain DoH
#   (doh-server=/域名/URL 形态: AI 9 行 + LinkedIn/Quora/Tumblr/Reddit 9 行)
#
# 原因 (经 QX 官方全语法样例 KOP-XIAO/QuantumultX_Profiles.conf 与
#   DivineEngine QX DNS 教程双重核实): QX 的 per-domain DNS 仅支持
#   明文形态 server=/域名/IP; doh-server 只有全局形态, 不存在
#   doh-server=/域名/URL 语法. 这 18 行为无效指令, "AI 强制境外 DoH
#   防污染"与 v5.1.5 修 LinkedIn/Quora 的"方向A"自引入起从未生效.
#
# 为什么功能一直正常: 这些域名被 [filter_remote] 规则送入代理后由
#   节点【远端解析】, 连通不依赖本地解析. 实际损失仅隐私面——
#   国内 DoH (阿里/腾讯) 能看到你查询过这些域名 (仅域名, 非内容).
#
# 架构结论 (实事求是): QX 无 Fake-IP、无 per-domain DoH, 在 QX 内
#   无法实现"境外域名加密境外解析". 替代写法 server=/域名/8.8.8.8
#   是明文 UDP:53, 在国内必被污染, 比无效更糟, 不采用. 若在意
#   "查询记录不落国内 DoH", 请用 Loon/Egern (架构支持) 承担该场景.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 国内高频服务: 强制系统 DNS (拿就近 CDN)
server=/*.apple.com/system
server=/*.icloud.com/system
server=/*.icloud-content.com/system
server=/*.mzstatic.com/system
server=/*.aaplimg.com/system

server=/*.taobao.com/system
server=/*.tmall.com/system
server=/*.alipay.com/system
server=/*.alicdn.com/system
server=/*.aliyuncs.com/system
server=/*.jd.com/system
server=/*.qq.com/system
server=/*.weixin.qq.com/system
server=/*.bilibili.com/system
server=/*.douyin.com/system
server=/*.douyincdn.com/system
server=/*.xiaohongshu.com/system
server=/*.weibo.cn/system
server=/*.weibo.com/system
server=/*.weibocdn.com/system
server=/*.sinaimg.cn/system

# 国内 Google 代理
server=/dl.google.com/119.29.29.29
server=/dl.l.google.com/119.29.29.29
server=/update.googleapis.com/119.29.29.29
server=/*.dl.playstation.net/119.29.29.29

# 路由器/局域网
server=/amplifi.lan/system
server=/router.synology.com/system
server=/router.asus.com/system
server=/routerlogin.net/system
server=/orbilogin.com/system
server=/myrouter.local/system
server=/miwifi.com/system
server=/www.miwifi.com/system
server=/mediarouter.home/system
server=/tplogin.cn/system
server=/tplinklogin.net/system
server=/melogin.cn/system
server=/falogin.cn/system


# =====================================
# [policy] - 继承 v5.1.3 (防抖优化 + 稳定池)
# =====================================
[policy]

# ---------- 场景组 (static) ----------
static=兜底策略, 自动选择, 稳定选择, 香港节点, 狮城节点, 日本节点, 台湾节点, 美国节点, 韩国节点, direct, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Final.png

static=人工智能, 狮城节点, 日本节点, 美国节点, 台湾节点, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/ChatGPT3.png

static=Spotify, 狮城节点, 日本节点, 香港节点, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Spotify.png

static=电报消息, 狮城稳定, 日本稳定, 美国稳定, 狮城节点, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Telegram_01.png

static=谷歌服务, 狮城节点, 日本节点, 香港节点, 美国节点, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Google.png

static=海外抖音, 日本节点, 台湾节点, 韩国节点, 美国节点, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/TikTok_2.png

static=大陆抖音, direct, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Tiktok_06.png

static=苹果服务, direct, 自动选择, 香港节点, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/Apple.png

static=Netflix, 狮城节点, 香港节点, 日本节点, 自动选择, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Netflix.png
static=Disney+, 香港节点, 日本节点, 美国节点, 自动选择, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Disney+.png
static=YouTube, 谷歌服务, 狮城节点, 香港节点, 日本节点, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png

# 长连接业务专用 (Instagram / Twitter / Threads) - 防风控漂移
static=Instagram, 美国稳定, 日本稳定, 狮城稳定, 兜底策略, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Instagram.png

static=推特, 美国稳定, 日本稳定, 狮城稳定, 兜底策略, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Twitter_01.png

# v5.1.5 新增: 社交阅读站专用 (LinkedIn/Quora/Tumblr/Reddit)
# 默认美国节点 (源站在美吞吐最好), 复用现有地区组 → 零能耗增加
static=社交阅读, 美国节点, 日本节点, 狮城节点, 自动选择, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Global.png

static=Github, 自动选择, 狮城节点, 日本节点, 美国节点, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/github_01.png

static=美国服务, 美国节点, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Googlevoice_03.png


# ---------- 地区组 (url-latency-benchmark) ----------
url-latency-benchmark=自动选择, server-tag-regex=^(?!.*(剩余|套餐|官网|流量|过期|更新|失联|网址|备用|测试|GB|MB)).*$, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Auto.png

url-latency-benchmark=香港节点, server-tag-regex=港|HK|Hong|🇭🇰, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/HK.png
url-latency-benchmark=台湾节点, server-tag-regex=台|TW|Taiwan|🇹🇼, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/icon/color/tw.png
url-latency-benchmark=美国节点, server-tag-regex=美|US|States|American|🇺🇸, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/US.png
url-latency-benchmark=日本节点, server-tag-regex=日|JP|Japan|🇯🇵, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/JP.png
url-latency-benchmark=韩国节点, server-tag-regex=韩|KR|Korea|🇰🇷, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/KR.png
url-latency-benchmark=狮城节点, server-tag-regex=新加坡|狮|獅|SG|🇸🇬, check-interval=600, tolerance=200, alive-checking=true, img-url=https://raw.githubusercontent.com/Orz-3/mini/master/Color/SG.png

# 稳定地区池 (IG/Twitter 长连接专用, interval=900 防漂移)
url-latency-benchmark=美国稳定, server-tag-regex=美|US|States|American|🇺🇸, check-interval=900, tolerance=300, alive-checking=true
url-latency-benchmark=日本稳定, server-tag-regex=日|JP|Japan|🇯🇵, check-interval=900, tolerance=300, alive-checking=true
url-latency-benchmark=狮城稳定, server-tag-regex=新加坡|狮|獅|SG|🇸🇬, check-interval=900, tolerance=300, alive-checking=true

# 稳定选择降级链 (static 类型, 可嵌套策略组)
static=稳定选择, 自动选择, 狮城稳定, 日本稳定, 美国稳定, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/Twoandz9/Fast.png


[server_local]


[server_remote]
https://YOUR_AIRPORT/subscribe?token=__REDACTED__, tag=良心云, update-interval=172800, opt-parser=false, enabled=true


# =====================================
# [filter_local] - v5.1.4 分级清理 + no-resolve 修复
# =====================================
[filter_local]
# 局域网保护
host-suffix, local, direct

# ---------- 高频重试源熔断 (QX 原生 reject) ----------
host, umc.danuoyi.alicdn.com, reject
host-suffix, mum.alibabachengdun.com, reject
host-suffix, siftscience.com, reject
host-keyword, pangolin-sdk-toutiao, reject
host-suffix, ctobsnssdk.com, reject
host-suffix, px.ucweb.com, reject
host-keyword, umeng, reject
host-keyword, adsdk, reject
host-suffix, xz.fbcdn.net, reject
host-suffix, xy.fbcdn.net, reject

# ---------- 微博保护区 (最先匹配, 避免被广告规则集误命中) ----------
# V26.00 [一致性] 补 weibo.com.cn / miaopai.com, 对齐 SR/Egern 保护区覆盖.
host-suffix, weibo.cn, direct
host-suffix, weibo.com, direct
host-suffix, weibo.com.cn, direct
host-suffix, weibocdn.com, direct
host-suffix, sinaimg.cn, direct
host-suffix, sina.cn, direct
host-suffix, sina.com.cn, direct
host-suffix, sinajs.cn, direct
host-suffix, miaopai.com, direct

# ---------- v5.1.4 保留: 财经/证券硬编码 (离线降级保险) ----------
# 理由: cert-pinning 长连接行情, 最怕 ChinaMax 远程加载失败时绕路.
# 视频/出行/工具类已删除, 交由 ChinaMax 兜底 (偶尔绕路无伤大雅).
host-suffix, myhexin.com, direct
host-suffix, eastmoney.com, direct
host-suffix, dfcfw.com, direct
host-suffix, xueqiu.com, direct
host-suffix, futunn.com, direct
host-suffix, itiger.com, direct
host-suffix, gtja.com, direct
host-suffix, citics.com, direct

# ---------- v5.1.6 新增: Quora 本地规则 (bm7 无 Quora 目录, 改本地覆盖) ----------
# 走社交阅读组, 立即生效不依赖远程订阅
host-suffix, quora.com, 社交阅读
host-suffix, quoracdn.net, 社交阅读

# ---------- V26.00: 谷歌翻译"连不上网"修复 ----------
# QUIC 陷阱本身已由 [general] udp_whitelist 全局挡 UDP443 解决(强制 TCP);
# 此处再显式钉谷歌服务组, 先于远程 Google 列表, 防其加载失败漏到兜底.
# 注: QX 无 per-domain 加密 DNS(架构限制), translate 解析走主 DoH,
#     经代理由节点远端解析, 不泄露/不污染.
host, translate-pa.googleapis.com, 谷歌服务
host-suffix, translate.googleapis.com, 谷歌服务
host-suffix, translate.google.com, 谷歌服务

# ---------- v5.1.4 修复: 国内 IP 兜底 (微信 VOIP / 纯 IP UDP) ----------
# 病灶修复: 补上 no-resolve, 避免对每个国内 IP 触发多余的 DNS 反查
# (既降延迟又降基带唤醒能耗). 与 fallback_udp_policy=direct 双重保护.
geoip, CN, direct, no-resolve

# 兜底
final, 兜底策略


# =====================================
# [filter_remote] - v5.1.4 能耗优化: update-interval 分级拉长
#   广告/隐私/ChinaMax: 3天 (259200)
#   AI/流媒体/社交:     7天 (604800)
# =====================================
[filter_remote]
# 广告与隐私 (3天)
