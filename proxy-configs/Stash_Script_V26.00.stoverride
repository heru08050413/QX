      timeout: 60
    - match: ^https?:\/\/haojia-api\.smzdm\.com\/home\/list
      name: "Smzdm"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/homepage-api\.smzdm\.com\/v3\/home
