name: "信息流去广告脚本合集 V26.00"
desc: "脚本级信息流/开屏去广告。覆盖:知乎·小红书·微博·淘宝·京东·爱奇艺·优酷·芒果TV·什么值得买·滴滴出行·大众点评·夸克·有道词典·阿里云盘。全部脚本已镜像进本仓库 scripts/,script-providers 只引自己 raw 链接=无第三方死链。需开 MITM 并信任证书。上游 @fmz200/@yichahucha/@zirawell,逻辑未改。不含银行/政务/证件类;B站/网易云/YouTube 依赖 webview/protobuf,Stash 跑不了,未收录。"

http:
  mitm:
    - "api.zhihu.com"
    - "page-info.zhihu.com"
    - "www.zhihu.com"
    - "appcloud2.zhihu.com"
    - "m-cloud.zhihu.com"
    - "edith.xiaohongshu.com"
    - "so.xiaohongshu.com"
    - "rec.xiaohongshu.com"
    - "www.xiaohongshu.com"
    - "api.weibo.cn"
    - "sub.weibo.cn"
    - "we.weibo.cn"
    - "guide-acs.m.taobao.com"
    - "poplayer.template.alibaba.com"
    - "api.m.jd.com"
    - "cards.iqiyi.com"
    - "access.if.iqiyi.com"
    - "comment-card.iqiyi.com"
    - "iface2.iqiyi.com"
    - "search.video.iqiyi.com"
    - "kjp.cupid.iqiyi.com"
    - "t7z.cupid.iqiyi.com"
    - "acs.youku.com"
    - "un-acs.youku.com"
    - "push.m.youku.com"
    - "me.bz.mgtv.com"
    - "mob-st.bz.mgtv.com"
    - "dc.bz.mgtv.com"
    - "dc2.bz.mgtv.com"
    - "mobile.api.mgtv.com"
    - "mobile-thor.api.mgtv.com"
    - "mobileso.bz.mgtv.com"
    - "*.smzdm.com"
    - "ct.xiaojukeji.com"
    - "freight.xiaojukeji.com"
    - "res.xiaojukeji.com"
    - "conf.diditaxi.com.cn"
    - "common.diditaxi.com.cn"
    - "daijia.kuaidadi.com"
    - "img.meituan.net"
    - "ddplus.meituan.net"
    - "open-cms-api.uc.cn"
    - "open-cms-api.quark.cn"
    - "dict.youdao.com"
    - "api.alipan.com"
    - "member.alipan.com"
  script:
    # zhihu
    - match: ^https:\/\/(?:api|page-info)\.zhihu\.com\/(?:answers|articles)\/v2\/\d+
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/commercial_api\/app_float_layer
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/feed\/render\/tab\/config\?
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/(?:moments_v3|topstory\/hot-lists\/total|topstory\/recommend)
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/root\/tab
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/v2\/topstory\/hot-lists\/everyone-seeing\?
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/bazaar\/vip_tab\/header\?
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/next-(?:bff|data|render)
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/api\.zhihu\.com\/questions\/\d+(?:\/answers|\/feeds|\?include=)
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/www\.zhihu\.com\/api\/v4\/(?:articles|answers)\/\d+\/recommendations?\?
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/appcloud2\.zhihu\.com\/v3\/config
      name: "zhihu"
      type: response
      require-body: true
    - match: ^https:\/\/m-cloud\.zhihu\.com\/api\/cloud\/config\/all\?
      name: "zhihu"
      type: response
      require-body: true
    # xiaohongshu
    - match: ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/(banner|hot)_list
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/(hint|trending)\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/(so|edith)\.xiaohongshu\.com\/api\/sns\/v\d+\/search\/notes\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/system_service\/config\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/system_service\/splash_config
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/edith\.xiaohongshu\.com\/api\/sns\/v\d+\/note\/widgets
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/v\d+\/note\/(imagefeed|live_photo\/save)
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/v\d+\/(followfeed|homefeed)\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/(v2\/note\/feed|v3\/note\/videofeed)\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/(edith|rec|www)\.xiaohongshu\.com\/api\/sns\/(v4\/note\/videofeed|v10\/note\/video\/save)\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    - match: ^https:\/\/edith\.xiaohongshu\.com\/api\/sns\/(v5\/note\/comment\/list|v3\/note\/comment\/sub_comments)\?
      name: "xiaohongshu"
      type: response
      require-body: true
