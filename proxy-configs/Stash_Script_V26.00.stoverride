    - match: ^https?:\/\/mobileso\.bz\.mgtv\.com\/mobile\/recommend\/v2\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    # 什么值得买
    - match: ^https?:\/\/haojia\.m\.smzdm\.com\/detail_modul\/user_related_modul\?
