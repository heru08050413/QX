    - match: ^https:\/\/edith\.xiaohongshu\.com\/api\/sns\/v1\/interaction\/comment\/video\/download\?
      name: "xiaohongshu"
      type: response
      require-body: true
      timeout: 60
    # 微博
    - match: ^https?:\/\/(?:api|sub|we)\.weibo\.cn\/
      name: "weibo"
      type: response
      require-body: true
    # 淘宝
    - match: ^https?:\/\/guide-acs\.m\.taobao\.com\/gw\/mtop\.taobao\.(cloudvideo\.video\.query|wireless\.home\.splash\.awesome\.get)
      name: "myBlockAds"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/poplayer\.template\.alibaba\.com\/\w+\.json
      name: "myBlockAds"
      type: response
      require-body: true
      timeout: 60
    # 京东
    - match: ^https:\/\/api\.m\.jd\.com\/client\.action\?functionId=(deliverLayer|getTabHomeInfo|myOrderInfo|orderTrackBusiness|personinfoBusiness|start|welcomeHome)
      name: "jingdong"
      type: response
      require-body: true
      timeout: 60
    # 爱奇艺
    - match: ^https?:\/\/[\d\.]+\/3f1\/cards\.iqiyi\.com\/(views_home\/3\.0\/qy_home|waterfall\/3\.0\/feed)\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/access\.if\.iqiyi\.com\/3f1\/cards\.iqiyi\.com\/(views_category\/3\.0\/category_home|views_home\/3\.0\/qy_home|waterfall\/3\.0\/feed)\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/cards\.iqiyi\.com\/views_category\/3\.0\/(category_home|categorylib_content|film_hybrid)\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/cards\.iqiyi\.com\/(views_home\/3\.0\/qy_home|waterfall\/3\.0\/feed)\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/cards\.iqiyi\.com\/views_plt\/3\.0\/player_tabs_v2\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/cards\.iqiyi\.com\/views_search\/3\.0\/(hot_query_)?search\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/comment-card\.iqiyi\.com\/views_comment\/3\.0\/long_video_comments\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/iface2\.iqiyi\.com\/aggregate\/3\.0\/getMyMenus\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/iface2\.iqiyi\.com\/control\/3\.0\/init_proxy\?
      name: "cnftp"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/iface2\.iqiyi\.com\/fusion\/3\.0\/common_switch\?
