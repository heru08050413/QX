      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/res\.xiaojukeji\.com\/resapi\/activity\/xpget
      name: "didiAds"
      type: response
      require-body: true
      timeout: 60
    - match: ^https?:\/\/res\.xiaojukeji\.com\/resapi\/activity\/mget
      name: "didiAds"
