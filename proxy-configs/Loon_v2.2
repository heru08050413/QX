JP_Filter = NameRegex, FilterKey = "(?i)(🇯🇵|日本|JP|Japan)"
KR_Filter = NameRegex, FilterKey = "(?i)(🇰🇷|KR|Korea|KOR|首尔|韩|韓)"
SG_Filter = NameRegex, FilterKey = "(?i)(🇸🇬|新加坡|狮城|獅城|SG|Singapore)"


