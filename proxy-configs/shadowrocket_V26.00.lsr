# =====================================================================
# [Host]
#
# v2.6 说明: dns-direct-fallback-proxy = false 后,如果出现污染域名
# 直连失败,优先在此处用静态 hosts 修复,而不是退回 fallback-proxy。
# =====================================================================

# =====================================================================
# [Host]
#
# v2.6.2 重大重构: 实现"per-domain DNS 解析器路由"
#
# 设计原则:
#   - 国内 CDN / Apple / 银行 / 高频国内服务: server:system
#     → 让 iOS 系统 DNS (Wi-Fi 路由器/运营商 DNS) 解析,
#       返回的是国内 CDN 的就近边缘 IP, 速度最快
#   - 海外高敏感 (AI/Cloudflare): server:https://1.1.1.1/dns-query
#     → 强制走 Cloudflare DoH 解析, 不暴露给国内 DNS 也不被污染
#   - 极少数固定 IP 服务: 静态映射
#
# 这是 Shadowrocket 上能实现的最接近"DNS 路由分离"的方案。
# =====================================================================

[Host]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 国内 CDN / Apple / 银行 → 系统 DNS (拿就近边缘 IP)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Apple 系
*.apple.com = server:system
*.icloud.com = server:system
*.icloud.com.cn = server:system
*.icloud-content.com = server:system
*.mzstatic.com = server:system
*.cdn-apple.com = server:system
*.aaplimg.com = server:system

# 银行 (重要: 这些必须走系统 DNS, 避免被代理/境外 DoH 解析触发风控)
*.ccb.com = server:system
*.abchina.com.cn = server:system
*.psbc.com = server:system
*.cmbchina.com = server:system
*.icbc.com.cn = server:system
*.boc.cn = server:system
*.bankofchina.com = server:system
*.spdb.com.cn = server:system
*.cmbc.com.cn = server:system
*.ceb.cn = server:system

# 微信 / QQ / 腾讯
*.weixin.qq.com = server:system
*.wechat.com = server:system
*.qq.com = server:system
*.tencent.com = server:system
*.qcloud.com = server:system
*.myqcloud.com = server:system
*.qpic.cn = server:system
*.gtimg.cn = server:system

# 阿里系
*.taobao.com = server:system
*.tmall.com = server:system
*.alipay.com = server:system
*.alicdn.com = server:system
*.aliyun.com = server:system
*.aliyuncs.com = server:system

# 微博 (走直连, 用系统 DNS)
*.weibo.cn = server:system
*.weibo.com = server:system
*.weibocdn.com = server:system
*.sinaimg.cn = server:system
*.sina.com.cn = server:system

# 字节系国内
*.douyin.com = server:system
*.douyinpic.com = server:system
*.douyinstatic.com = server:system
*.douyinvod.com = server:system
*.douyincdn.com = server:system
*.bytecdn.cn = server:system
*.pstatp.com = server:system
*.snssdk.com = server:system
*.feishu.cn = server:system

# 其他国内大厂
*.baidu.com = server:system
*.jd.com = server:system
*.meituan.com = server:system
*.163.com = server:system
*.bilibili.com = server:system
*.zhihu.com = server:system
*.zhimg.com = server:system
*.xiaohongshu.com = server:system

# 国内 DNS 自身
*.alidns.com = server:system
*.doh.pub = server:system

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# v2.6.4 新增: 国内顶级域通配兜底 (架构级优化)
#
# 所有 .cn / .com.cn 顶级域 (几乎 100% 是国内主体) 统一走系统 DNS,
# 拿就近 CDN 边缘 IP. 一举覆盖财经/视频/物流/工具等所有未来出现的
# 国内 .cn 域名, 不再需要逐个 *.specific.cn = server:system 写法.
#
# 影响范围举例:
#   - 同花顺 10jqka.com.cn / thsi.cn / hexin.cn
#   - 兴业银行 cib.com.cn / 华泰 htsc.com.cn / 苏宁 suning.cn
#   - 酷狗酷我 kuwo.cn / WPS wps.cn / 顺丰 sf-express.com.cn
#   - 学习强国 xuexi.cn / 12306.cn / nic.cn / cnnic.cn
#   - 所有 *.gov.cn / *.edu.cn / *.ac.cn 政务教育
#
# 必须放在最后, 让前面的精确条目优先匹配 (Host 段是精确优先).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

*.cn = server:system
*.com.cn = server:system

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 海外高敏感 → Cloudflare DoH (避免国内 DNS 留痕)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# AI 核心服务 (Anthropic / OpenAI / Google AI)
claude.ai = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.anthropic.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
chat.openai.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.openai.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.chatgpt.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.oaistatic.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.oaiusercontent.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query

# Google AI (Gemini)
gemini.google.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
aistudio.google.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.generativelanguage.googleapis.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query

# 长连接 / 流媒体 (避免代理 DNS 与本地 DNS 不一致触发风控)
*.instagram.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.cdninstagram.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.twitter.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.x.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query
*.twimg.com = server:https://1.1.1.1/dns-query,https://1.0.0.1/dns-query

localhost = 127.0.0.1


# =====================================================================
# [URL Rewrite]
#
# 设计原则继承 v2.5: 不在此段做微博相关拦截。
# 微博广告全部交给 [Script] 段处理。
# =====================================================================

[URL Rewrite]
# Google CN 跳转修复
^https?://(www\.)?g\.cn https://www.google.com 302
^https?://(www\.)?google\.cn https://www.google.com 302

# V26.00 新增: Spotify 去广告配套改写 (001ProMax 方案移植, 与 [Script] 协同)
# ① pendragon = 广告/投放接口, 直接拒绝 (reject-dict 返回空 JSON, App 不重试)
^https://(\w+-spclient|spclient\.wg)\.spotify\.com(:443)?/pendragon/ - reject-dict
# ② artistview 平台参数 iphone→ipad, 恢复歌手页正常展示 (上游同款 header 改写)
^https://(\w+-spclient|spclient\.wg)\.spotify\.com(:443)?/artistview/v1/artist/(.*)&platform=iphone https://spclient.wg.spotify.com/artistview/v1/artist/$3&platform=ipad header

# v2.6.9 移除: googlevideo initplayback &oad reject 规则
# 原因: 该 rewrite 依赖对 *.googlevideo.com 做 MITM 解密才能匹配 path,
#       但 v2.6.9 已将 googlevideo 移出 MITM (降耗 P0). 失去 MITM 后
#       此 rewrite 无法生效, 故一并移除避免困惑.
# 影响: 视频流前贴片广告改由 youtubei 的 player 接口脚本处理
#       (Maasea youtube.response.js 移除广告 playback 配置),
#       去广告效果基本不变. 实测如有个别前贴片漏网, 收益也远不及
#       全程解密 googlevideo 大流量带来的发热/耗电代价.


# =====================================================================
# [Script]
#
# 命名约定: {App}{接口} = type=...
# 所有规则强制 max-size=-1 (否则 64KB 截断会导致脚本失效)
#
# v2.6 扩充: 微博接口扩 5 个 + 新增 8 个国内 App 脚本
# =====================================================================

[Script]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# v2.6.3 脚本信任元数据规约 (强制)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 每个脚本块必须包含以下元数据:
#   SOURCE          上游 GitHub repo 完整 URL
#   TRUST           HIGH | MEDIUM | LOW
#   LAST-VERIFIED   YYYY-MM-DD 上次维护者人工审计脚本内容的日期
#
# 信任等级判定:
#   HIGH    多人 contributor, 历史无投毒事件, > 1000 stars
#   MEDIUM  单人维护但活跃, < 6 个月内有 commit
#   LOW     长期未更新或维护者身份不明
#
# 维护规约:
#   - 每 30-60 天审计 TRUST=MEDIUM 的脚本, 更新 LAST-VERIFIED
#   - LAST-VERIFIED > 90 天的脚本在下次大扫除时优先评估去留
#   - TRUST 等级不是静态的, 任何投毒事件或 abandon 都应立即降级
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 微博
# SOURCE:        https://github.com/zmqcherish/proxy-script
# TRUST:         MEDIUM (单人维护, 活跃度高, 微博生态社区认可度好)
# LAST-VERIFIED: 2026-05-19
# NOTES:         维护者 zmqcherish 是微博脚本社区长期活跃成员.
#                每次微博 App 更新后, 此脚本通常 1-3 天内跟进.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 主接口 (信息流/详情页/评论/搜索/超话/转发流) — v2.6 扩展 pattern
微博主体去广告 = type=http-response,pattern=^https?://m?api\.weibo\.c(n|om)/2/(cardlist|searchall|page|messageflow|statuses/(unread_)?friends(/|_)timeline|groups/timeline|statuses/(container_timeline|unread_hot_timeline|extend|video_mixtimeline|repost_timeline|show)|profile/(me|info|container_timeline)|video/(community_tab|remind_info|tiny_stream_video_list)|checkin/show|\!/live/media_homelist|comments/(build_comments|hotflow)|container/get_item|search/(finder|container_timeline|container_discover)|photo/info|\!/client/active_box),requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/weibo_main.js

# 开屏广告 — v2.6 扩展域名通配
微博开屏去广告 = type=http-response,pattern=^https?://(sdk|wb)app\.(mob\.)?uve\.weibo\.com/(interface/sdk/sdkad\.php|wbapplua/wbpullad\.lua),requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/weibo_launch.js

# 备用开屏接口 (mapi.weibo.com 路径, 部分版本会回退到此)
微博开屏备用 = type=http-response,pattern=^https?://m?api\.weibo\.c(n|om)/2/!/client/(wbpullad|sdkad|splash|launch|openscreen),requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/weibo_launch.js

# Tab 自定义图标
微博Tab自定义 = type=http-response,pattern=^https://api\.weibo\.cn/2/!/client/light_skin,requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/weibo_main.js

# 非会员皮肤解锁
微博皮肤解锁 = type=http-response,pattern=^https://new\.vip\.weibo\.cn/littleskin/preview,requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/weibo_main.js

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# B站
# SOURCE:        https://github.com/zmqcherish/proxy-script/tree/main/bilibili
# TRUST:         MEDIUM (同微博, 同维护者)
# LAST-VERIFIED: 2026-06-30
#
# V26.00 换源修复 (死链巡检发现):
#   上游已大幅重构: bilibili_proto.js / bilibili_json.js 均已删除 (404),
#   原 6 条脚本 (proto/首页/搜索/番剧/直播/资源页/我的页) 自上游重构起
#   全部静默失效. 上游现行仅提供【单接口单脚本】: /x/v2/feed/index
#   首页流去广告 → bilibili/bilibili.js (已核验 200), pattern 按上游
#   现行 bilibili.conf 同步 (新增 app.biliapi.net 域, 已同步 MITM).
#   其余 5 个接口为上游主动放弃, 无同源替代, 不臆造.
#
#   ⚠️ B 站去广告主力已在 Egern (BiliUniverse ADBlock 模块, 事实标准).
#   SR 侧如需更强 B 站去广告: App 内 [配置 → 模块] 添加
#   https://github.com/BiliUniverse/ADBlock/releases/latest/download/BiliBili.ADBlock.sgmodule
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

B站首页 = type=http-response,pattern=^https://(app\.biliapi\.net|app\.bilibili\.com)/x/v2/feed/index,requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/zmqcherish/proxy-script/main/bilibili/bilibili.js

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 微信公众号
# SOURCE:        https://github.com/NobyDa/Script
# TRUST:         HIGH (NobyDa 是 iOS 代理脚本社区资深维护者,
#                      多年活跃, 跨多个仓库 cross-validation)
# LAST-VERIFIED: 2026-05-19
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

微信公众号去广告 = type=http-response,pattern=^https?://mp\.weixin\.qq\.com/mp/getappmsgad,requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/NobyDa/Script/master/QuantumultX/File/Wechat.js

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 知乎
# SOURCE:        https://gist.github.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18
# TRUST:         HIGH (blackmatrix7 是 ios_rule_script 主要维护者)
# LAST-VERIFIED: 2026-05-19
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

知乎个人页 = type=http-response,pattern=^https?://api\.zhihu\.com/people/,requires-body=1,max-size=-1,script-path=https://gist.githubusercontent.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18/raw/zheye.min.js
知乎推荐流 = type=http-response,pattern=^https://api\.zhihu\.com/topstory/recommend,requires-body=1,max-size=-1,script-path=https://gist.githubusercontent.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18/raw/zheye.min.js
知乎评论 = type=http-response,pattern=^https?://api\.zhihu\.com/(comment_v5/)?(answers|comments?|articles|pins)/\d+/(root_|child_)?comments?,requires-body=1,max-size=-1,script-path=https://gist.githubusercontent.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18/raw/zheye.min.js
知乎问答 = type=http-response,pattern=^https?://api\.zhihu\.com/(v4/)?questions/\d+,requires-body=1,max-size=-1,script-path=https://gist.githubusercontent.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18/raw/zheye.min.js
知乎热榜 = type=http-response,pattern=^https?://api\.zhihu\.com/topstory/hot-lists?(\?|/),requires-body=1,max-size=-1,script-path=https://gist.githubusercontent.com/blackmatrix7/f5f780d0f56b319b6ad9848fd080bb18/raw/zheye.min.js

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 高德地图
# SOURCE:        https://github.com/ddgksf2013/Scripts
# TRUST:         MEDIUM (单人维护, 历史上有过大幅重构)
# LAST-VERIFIED: 2026-05-19
# NOTES:         此仓库下脚本变动较频繁, 建议每 30 天审计一次.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

高德开屏 = type=http-response,pattern=^https?://.*\.amap\.com/ws/valueadded/alimama/splash_screen,requires-body=1,max-size=-1,script-path=https://github.com/ddgksf2013/Scripts/raw/master/amap.js
高德弹窗 = type=http-response,pattern=^https?://.*\.amap\.com/ws/msgbox/pull,requires-body=1,max-size=-1,script-path=https://github.com/ddgksf2013/Scripts/raw/master/amap.js
高德横幅 = type=http-response,pattern=^https?://.*\.amap\.com/ws/faas/amap-navigation/main-page,requires-body=1,max-size=-1,script-path=https://github.com/ddgksf2013/Scripts/raw/master/amap.js

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# YouTube (去广告 + 画中画 PiP + 后台播放 + 翻译)
# SOURCE:        https://github.com/Maasea/sgmodule
# TRUST:         HIGH (Maasea 仓库长期稳定, 跨平台模块大量复用)
# LAST-VERIFIED: 2026-05-21
#
# v2.6.7 重大升级 (本次新增浮窗/后台播放功能的核心):
#   旧版问题: v2.6.6 用的单文件 youtube.js 是 Maasea 的过时架构,
#             pattern 缺少 account/get_setting 和 get_watch 接口.
#             - account/get_setting: 控制后台播放/画中画开关的接口
#             - get_watch: 2024-06 YouTube 新增, 旧脚本会导致播放页
#               去广告和画中画失效 (见 Maasea issue #57)
#   新版方案: 升级为官方当前的 request + response 双脚本架构,
#             补全所有 youtubei/v1 接口. 这才能真正解锁:
#             ✓ 去广告 (瀑布流/视频/搜索/Shorts)
#             ✓ 画中画 PiP (退出 App 时浮窗继续播放)
#             ✓ 后台播放 (锁屏/切后台音频继续)
#             ✓ 字幕/歌词翻译 (可选)
#
#   配套依赖 (缺一不可, 已在对应段落添加):
#     1. [Rule] 段: googlevideo.com + youtubei UDP REJECT
#        → 强制 YouTube 走 TCP, 否则 QUIC 绕过脚本, 解锁失效
#     2. MITM hostname: 已包含 youtubei.googleapis.com (无需改)
#
#   启用后客户端操作 (重装 App 后):
#     设置 → 播放 → 画中画: 开启
#     设置 → 后台播放和下载 → 后台播放: 开启
#
#   注意: 音乐类内容 (官方 MV/Art Track) 的后台播放仍需 Premium,
#         这是服务端限制, 脚本无法绕过. 普通视频不受此限.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# V26.00 换源修复 (死链巡检发现):
#   上游 Maasea 已回归【单 response 脚本】架构, youtube.request.js 已删除
#   (404, 原 request 行自上游删除起静默失效). 现行 YouTube.Enhance.sgmodule
#   (已核验) 仅含 response 脚本; pattern 与 argument 按上游现行同步.
# response 脚本 (改写服务端响应, 去广告 + 解锁后台播放/PiP + 翻译)
# argument 说明: blockUpload=屏蔽上传按钮, blockImmersive=屏蔽选段,
#               blockShorts=屏蔽Shorts(默认 false 保留), 翻译默认 off
YouTube.response = type=http-response,pattern=^https://youtubei\.googleapis\.com/(youtubei/v1/(browse|next|player|search|reel/reel_watch_sequence|guide|account/get_setting|get_watch))(\?(.*))?$,requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js,argument={"lyricLang":"off","captionLang":"off","blockUpload":true,"blockImmersive":true,"blockShorts":false,"debug":false}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Spotify
# SOURCE:        https://github.com/001ProMax/Surge (上游作者 app2smile/001ProMax)
# TRUST:         MEDIUM (社区现行方案, Loon 侧已在用同源 plugin 且实测有效)
# LAST-VERIFIED: 2026-06-30
#
# V26.00 换源修复 (死链巡检发现):
#   原 NobyDa/Script/.../Surge/JS/Spotify.js 已被上游删除 (404, 同仓库
#   其他文件仍 200, 系删文件非迁移), 原脚本静默失效. 换用 Loon 配置里
#   已在用且已核验 200 的 001ProMax 方案, 按 SR 语法移植三件套:
#   ① pendragon 广告/投放接口 → URL Rewrite reject-dict (见 [URL Rewrite])
#   ② artistview 平台参数改写恢复歌手页 → URL Rewrite header (同上)
#   ③ bootstrap/user-customization protobuf 改写 → 下方脚本
#   argument 说明: [true,true] = [移除底栏创建按钮, 启用Apple设备接力],
#   为 Loon plugin 参数模板展开后的等价字面量.
#   MITM 需含 *-spclient.spotify.com 与 spclient.wg.spotify.com (已同步).
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Spotify去广告 = type=http-response,pattern=^https://(?:\w+-spclient|spclient\.wg)\.spotify\.com(?::443)?/(?:bootstrap|user-customization-service),requires-body=1,max-size=-1,binary-body-mode=1,script-path=https://raw.githubusercontent.com/001ProMax/Surge/refs/heads/main/Script/Spotify.Crack.Dev.js,argument=[true,true]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 国内主流 App 开屏 / 信息流广告改写
# SOURCE:        (原 ddgksf2013/Scripts/master/Filter/*, 已整库重构失效)
# TRUST:         —
# LAST-VERIFIED: 2026-06-30 (死链巡检)
#
# V26.00 换源修复 (死链巡检发现, 本段为最大一处静默失效):
#   原 10 条脚本 (小红书×2/京东/拼多多/美团/网易云/爱奇艺/腾讯视频/
#   芒果TV/12306/滴滴) 的上游 ddgksf2013/Scripts/master/Filter/ 目录已
#   整体重构删除 (逐条核验 404; 讽刺的是配置注释早预警过该仓库"多次
#   大幅重构,直接引用 master 风险较高"). 这 10 条自上游重构起全部
#   静默失效 — 即国内 App 开屏去广告实际早已不工作.
#
#   ★ 换源方案 (净升级, 覆盖从 10 App → 730+ App):
#   SR 支持 Surge 模块. 请在 App 内 [配置 → 模块] 添加 fmz200 blockAds
#   (活跃维护, 已核验 200, Loon/Egern 侧同源且用户实测有效):
#     https://raw.githubusercontent.com/fmz200/wool_scripts/main/Surge/module/blockAds.module
#   模块会自动注入所需 MITM hostname (%APPEND%), 无需改本配置.
#
#   为什么不在配置里逐条重写: ① 上游新路径不存在/自托管域无法核验,
#   逐条臆造 pattern 必然再次腐坏; ② 模块化后升级由上游统一维护,
#   根治"配置内散装脚本静默腐坏"这一类问题(本次巡检 13 处死链的教训).
#   对应的 12 个无脚本 MITM hostname 已从本配置移除(避免无效解密耗电),
#   启用模块后由模块自带 hostname 接管.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# =====================================================================
# [MITM]
#
# v2.6.2 重大改进: 在通配 *.weibo.cn / *.sinaimg.cn 等的基础上,
# 显式排除所有 sinaimg/weibocdn 的图片/视频 CDN 子域。
#
# 原因 (日志 2 证据):
#   ad.us.sinaimg.cn 上 720p HEVC 视频被完整 MITM 解密,
#   图片/视频 chunk 加密-解密-再加密, 卡顿和首屏延迟由此而来。
#   脚本根本不会处理图片字节, MITM 对图片/视频无意义。
#
# 同时保留 v2.6.1 的高敏感子域排除 (登录/支付/账户/安全)
# =====================================================================

[MITM]
enable = true
h2 = true
client-source-address = false

# v2.6.5 改进: MITM hostname 进一步精确化
#
# v2.6.5 关键改动:
#   - *.amap.com (通配) → 精确接口列表 (3 个广告接口域名)
#     原因: 通配会让所有 amap 子域走解密, 包括账户/钱包/搜索等无关流量.
#           实测高德广告接口 90 天内稳定, 改为精确收益 > 维护成本.
#           v2.6.5 仅列脚本实际处理的: 开屏/弹窗/横幅三接口对应的域.
#
# 已沿用 v2.6.3 的精确化 (历史):
#   - *.bilibili.com   → 只保留 app.bilibili.com 等 5 个接口域名
#   - *.zhihu.com      → 只保留 api.zhihu.com
#
# 保留的通配 (有充分理由):
#   - *.weibo.cn / *.weibo.com / *.weibo.com.cn / *.weibocdn.com
#     原因: 微博接口分散在 api/m/mapi/wbapp/new.vip 等子域, 收窄会
#           立刻让脚本失效. 已用显式排除保护 passport/login/security/
#           pay/图片 CDN 共 26 个高敏感子域, 这是当前最佳平衡.
#   - *.sina.cn / *.sina.com.cn / *.sinaimg.cn / *.sinajs.cn
#     原因: 微博域名联动, 同上.
#
# V26.00 [一致性] 显式排除 银行/支付/icloud, 对齐安全基线(CLAUDE.md §一.1)
#   与 QX/Loon/Egern 一致. SR 的 hostname 本是白名单, 这些域当前不在
#   includes 故本就不解密; 显式 -exclude 是防御纵深: 未来若有人放宽某条
#   include 通配, 这些高敏感域仍被钉死不解密. 零功能风险.
# V26.00 hostname 同步 (随脚本换源):
#   + app.biliapi.net (B站现行接口域) / + *-spclient.spotify.com (Spotify 新方案)
#   - B站旧接口域 5 个、国内 App 12 个无脚本 hostname (脚本已死/移交
#     blockAds 模块, 留着=无效解密纯耗电; 模块启用后自动 %APPEND% 接管)
hostname = -*.alipay.com, -*.unionpay.com, -*.cmbchina.com, -*.icbc.com.cn, -*.icloud.com, -passport.weibo.cn, -login.sina.com.cn, -security.weibo.cn, -pay.weibo.cn, -account.bilibili.com, -passport.bilibili.com, -pay.bilibili.com, -account.zhihu.com, -wx1.sinaimg.cn, -wx2.sinaimg.cn, -wx3.sinaimg.cn, -wx4.sinaimg.cn, -tva1.sinaimg.cn, -tva2.sinaimg.cn, -tva3.sinaimg.cn, -tva4.sinaimg.cn, -ww1.sinaimg.cn, -ww2.sinaimg.cn, -ww3.sinaimg.cn, -ww4.sinaimg.cn, -tvax1.sinaimg.cn, -tvax2.sinaimg.cn, -tvax3.sinaimg.cn, -tvax4.sinaimg.cn, -us.sinaimg.cn, -video.weibocdn.com, -img.t.sinajs.cn, *.weibo.cn, *.weibo.com, *.weibo.com.cn, *.weibocdn.com, *.sina.cn, *.sina.com.cn, *.sinaimg.cn, *.sinajs.cn, app.bilibili.com, app.biliapi.net, mp.weixin.qq.com, api.zhihu.com, m5.amap.com, restapi.amap.com, mps.amap.com, youtubei.googleapis.com, spclient.wg.spotify.com, *-spclient.spotify.com


